---
import Layout from '../layouts/Layout.astro'

<Layout title="Thoughts — Jehan">
  <div class="bg-[#f5f5f5] px-4 py-8 md:py-12 overflow-hidden">
    <div class="mx-auto max-w-7xl h-full">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div class="lg:col-span-2">
          <h1 class="text-3xl font-bold text-gray-900 font-mono mb-6">Thoughts</h1>
          <div class="text-gray-500">Thoughts coming soon...</div>
        </div>
      </div>
    </div>
  </div>
</Layout>
