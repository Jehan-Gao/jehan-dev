---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'
import { formatDate } from '../../utils/date'
import ChevronRight from '../../components/icons/ChevronRight.astro'

interface Props {
  slug: string
}

const { slug } = Astro.props

const posts = await getCollection('posts')
const post = posts.find(p => p.id === slug)

if (!post) {
 Astro.response = new Response('Not Found', { status: 404 })
}

---

<Layout title={`${post.data.title} — Jehan`}>
  <div class="bg-[#f5f5f5] px-4 py-8 md:py-12 overflow-hidden">
    <div class="mx-auto max-w-3xl h-full">
      <nav class="flex items-center gap-1.5 font-mono text-xs text-gray-500 sm:text-sm mb-6">
        <a href="/" class="transition-colors hover:text-gray-900">~</a>
        <span class="text-gray-300">/</span>
        <a href="/posts" class="transition-colors hover:text-gray-900">posts</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-900 truncate">{post.id}</span>
      </nav>
      
      <article class="prose max-w-none">
        <h1 class="text-3xl font-bold text-gray-900 font-mono mb-4">{post.data.title}</h1>
        <time class="text-sm text-gray-500 font-mono mb-6 block" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        <div class="text-gray-800 leading-relaxed">
          {post.body}
        </div>
      </article>
    </div>
  </div>
</Layout>
