---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import { formatDate } from '../../utils/date'
import ChevronRight from '../../components/icons/ChevronRight.astro'

const posts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true
})

const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<Layout title="Posts — Jehan">
  <div class="min-h-screen bg-[#f5f5f5] text-gray-900">
    <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
      <nav class="flex items-center gap-1.5 text-xs sm:text-sm text-gray-500 mb-6 sm:mb-8 font-mono">
        <a href="/" class="hover:text-gray-900 transition-colors">~</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-900">posts</span>
      </nav>

      <div class="relative border border-gray-200 bg-white p-4 sm:p-6">
        <div class="mb-6 flex items-center justify-between border-b border-gray-100 pb-4">
          <h1 class="text-lg font-semibold text-gray-900 font-mono">Posts</h1>
          <span class="px-2 py-0.5 text-sm bg-gray-100 text-gray-600 font-mono">
            {sortedPosts.length}
          </span>
        </div>

        <ul class="space-y-1">
          {sortedPosts.map((post) => (
            <li>
              <a
                href={`/posts/${post.id}`}
                class="group flex items-center justify-between p-3 min-h-[3.25rem] transition-colors hover:bg-gray-50 border border-transparent hover:border-gray-200"
              >
                <div>
                  <h3 class="font-medium text-gray-900 group-hover:text-gray-700">
                    {post.data.title}
                    {post.data.draft && (
                      <span class="ml-2 px-1.5 py-0.5 text-xs bg-gray-200 text-gray-600">Draft</span>
                    )}
                    {post.data.wip && (
                      <span class="ml-2 px-1.5 py-0.5 text-xs bg-amber-100 text-amber-700">WIP</span>
                    )}
                  </h3>
                  <time
                    class="text-xs text-gray-500 font-mono"
                    datetime={post.data.date.toISOString()}
                  >
                    {formatDate(post.data.date)}
                  </time>
                </div>
                <ChevronRight class="h-4 w-4 text-gray-400 transition-transform group-hover:translate-x-0.5" />
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</Layout>