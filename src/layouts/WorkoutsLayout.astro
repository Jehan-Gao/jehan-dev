---
import LightBox from '../LightBox.astro'
import Layout from '../layouts/Layout.astro'

interface Props {
  title: string
}

const { title } = Astro.props
---

<Layout title={title}>
  <div class="bg-[#f5f5f5] px-4 py-8 md:py-12 overflow-hidden">
    <div class="mx-auto max-w-7xl h-full">
      <slot />
    </div>
  </div>
  <LightBox />
</Layout>
