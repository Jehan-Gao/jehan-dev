---
interface Props {
  class?: string
}

const { class: className = '' } = Astro.props
---

<div class={`signature-root ${className}`} data-signature-root>
  <svg class="signature-svg" viewBox="0 0 140 40" aria-hidden="true">
    <circle class="signature-dot" cx="20" cy="5" r="1.5" pathLength="1" />
    <path
      class="signature-path"
      pathLength="1"
      d="M20 10 L20 32 Q20 36 16 36
         Q24 36 28 30 Q32 24 32 32 Q32 38 28 38 Q24 38 24 32 L24 10
         Q24 6 30 6 Q36 6 36 12 L36 36
         Q36 40 32 40 Q28 40 28 36 Q28 32 32 28 Q36 24 36 32
         Q36 38 32 38 Q28 38 28 32 L28 10
         Q28 6 34 6 Q40 6 40 12 L40 36
         Q40 40 36 40 Q32 40 32 36 Q32 30 36 28 Q40 26 40 32
         Q40 38 36 38 Q32 38 32 32 L32 10
         Q32 6 38 6 Q44 6 44 12 L44 36"
    />
  </svg>
</div>

<script>
 const DEFAULT_DURATION_MS = 2400
 const EASING = 'cubic-bezier(0.4, 0, 0.2, 1)'

 function setupSignature(root: Element): void {
   const mainPath = root.querySelector<SVGPathElement>('.signature-path')
   const dot = root.querySelector<SVGPathElement>('.signature-dot')
   if (!mainPath) {
     return
   }

   let token = 0
   const cssDuration = Number.parseFloat(getComputedStyle(root).getPropertyValue('--signature-duration'))
   const durationMs = Number.isFinite(cssDuration) && cssDuration > 0
     ? cssDuration * 1000
     : DEFAULT_DURATION_MS

   function showDot(): void {
     if (dot) {
       dot.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 200, fill: 'forwards' })
     }
   }

   function hideDot(): void {
     if (dot) {
       dot.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 100, fill: 'forwards' })
     }
   }

   const path = mainPath

   async function play(from: number, to: number, duration: number): Promise<void> {
     const animation = path.animate(
       [{ strokeDashoffset: String(from) }, { strokeDashoffset: String(to) }],
       {
         duration: Math.max(1, duration),
         easing: EASING,
         fill: 'forwards',
       },
     )

     try {
       await animation.finished
       path.style.strokeDashoffset = String(to)
       if (to === 0) showDot()
     }
     catch {
       // Animation was cancelled (e.g. mouseenter), ignore
     }
   }

   function getOffset(): number {
     const offset = Number.parseFloat(getComputedStyle(path).strokeDashoffset)
     if (Number.isNaN(offset)) {
       return 0
     }

     return Math.max(0, Math.min(1, offset))
   }

   void play(1, 0, durationMs)

   root.addEventListener('mouseenter', () => {
     token += 1
     const run = token
     const offset = getOffset()
     path.getAnimations().forEach(animation => animation.cancel())
     hideDot()

     const reverseDuration = Math.round(durationMs * (1 - offset))

     void play(offset, 1, reverseDuration).then(() => {
       if (run !== token) {
         return
       }

       void play(1, 0, durationMs)
     })
   })
 }

 document.querySelectorAll('[data-signature-root]').forEach((root) => {
   setupSignature(root)
 })
</script>

<style>
  .signature-root {
    --signature-stroke: #94a3b8;
    --signature-duration: 2.4s;
    display: inline-block;
  }

  .signature-svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .signature-dot {
    fill: var(--signature-stroke);
    opacity: 0;
  }

  .signature-path {
    fill: none;
    stroke: var(--signature-stroke);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }
</style>
