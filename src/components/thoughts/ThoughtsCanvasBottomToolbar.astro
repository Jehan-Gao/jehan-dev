---
import CornerMarkers from '../CornerMarkers.astro'

interface Props {
  class?: string
  viewMode?: 'canvas' | 'list'
  setViewMode?: (mode: 'canvas' | 'list') => void
}

const { class: className, viewMode = 'canvas', setViewMode } = Astro.props
---

<div class:list={['relative flex items-center justify-center gap-2 px-3 py-1.5 text-xs text-gray-600 font-mono border-t border-gray-100', className]}>
  <CornerMarkers />
  <button
    aria-pressed={viewMode === 'canvas'}
    onClick={() => setViewMode?.('canvas')}
    class="inline-flex items-center gap-1.5 transition-colors hover:text-gray-900"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5">
      <rect x="3" y="3" width="7" height="7"></rect>
      <rect x="14" y="3" width="7" height="7"></rect>
      <rect x="14" y="14" width="7" height="7"></rect>
      <rect x="3" y="14" width="7" height="7"></rect>
    </svg>
    Canvas
  </button>
  <button
    aria-pressed={viewMode === 'list'}
    onClick={() => setViewMode?.('list')}
    class="inline-flex items-center gap-1.5 transition-colors hover:text-gray-900"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5">
      <line x1="8" y1="6" x2="21" y2="6"></line>
      <line x1="8" y1="12" x2="21" y2="12"></line>
      <line x1="8" y1="18" x2="21" y2="18"></line>
      <line x1="3" y1="6" x2="3.01" y2="6"></line>
      <line x1="3" y1="12" x2="3.01" y2="12"></line>
      <line x1="3" y1="18" x2="3.01" y2="18"></line>
    </svg>
    List
  </button>
</div>
